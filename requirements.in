numpy
pillow
pyyaml
opencv-python

# CUDA torch wheels come from the PyTorch index URL on the build host,
# not from PyPI. See docs/LINUX_WHEELHOUSE_BUILD.md.
torch
torchvision

# Both RF-DETR and SAM2 are loaded via HF transformers AutoModel / AutoProcessor
# from downloaded HF weights directories (config.json + model.safetensors).
transformers

# ONNX runtime — only needed if you deploy an ONNX-exported model on the
# air-gapped target (RF-DETR / SAM2 ONNX produced by the convert scripts under
# scripts/rfdetr-onnx-convert and scripts/sam2-onnx-convert).
# For Blackwell sm_120 you need ORT >= 1.20 built against CUDA 12.x.
# On a CPU-only dev Mac use `onnxruntime` instead — the two packages conflict.
onnxruntime-gpu
